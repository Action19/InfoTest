# Production Environment Variables for Render.com

NODE_ENV=production
PORT=5000

# JWT Configuration (Render will auto-generate JWT_SECRET)
JWT_EXPIRE=7d

# CORS Origin (Your Netlify frontend URL)
CORS_ORIGIN=https://infotest-platform.netlify.app

# Database (SQLite - will be created automatically)
# Note: Render's free tier has ephemeral filesystem
# Database will reset on each deploy unless using persistent storage
